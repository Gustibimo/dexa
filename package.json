{
  "name": "dexa-employee-attendance",
  "version": "1.0.0",
  "private": true,
  "description": "Employee WFH Attendance System",
  "workspaces": [
    "backend",
    "frontend/employee-app",
    "frontend/admin-app"
  ],
  "scripts": {
    "backend:dev": "npm run start:dev --workspace=backend",
    "employee-app:dev": "npm run dev --workspace=frontend/employee-app",
    "admin-app:dev": "npm run dev --workspace=frontend/admin-app",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  }
}
